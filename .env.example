# Google Drive 연동 (Phase 1)
# Google Cloud Console에서 OAuth 2.0 Client ID(웹 애플리케이션)를 발급받아 채우세요.
#   1. https://console.cloud.google.com 에서 프로젝트 생성
#   2. "API 및 서비스" > Google Drive API 활성화
#   3. "사용자 인증 정보" > OAuth 2.0 클라이언트 ID(웹) 생성
#   4. 승인된 JavaScript 원본에 http://localhost:5173 추가
#   5. 아래에 클라이언트 ID를 붙여넣고 이 파일을 .env.local 로 복사
VITE_GOOGLE_CLIENT_ID=

# 읽기 전용으로 시작하려면 drive.readonly, 편집 저장까지 하려면 drive 로 변경
VITE_GOOGLE_SCOPE=https://www.googleapis.com/auth/drive

# (선택) 볼트 루트 폴더 지정. 비우면 내 드라이브 루트부터 .md를 탐색합니다.
#   - 폴더 ID(권장): Drive에서 폴더 URL의 .../folders/<ID> 부분
VITE_VAULT_FOLDER_ID=
#   - 또는 폴더 이름(ID가 없을 때 이름으로 조회)
VITE_VAULT_FOLDER_NAME=
